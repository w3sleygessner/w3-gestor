# DESATIVA O PARSE DE MENSAGENS (Isso libera o processador para o login)
ENV WEBHOOK_GLOBAL_ENABLED=false
ENV CONFIG_SESSION_CONTROL_HANDLERS_MESSAGES_SET=false
